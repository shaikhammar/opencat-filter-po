{
    "name": "opencat/filter-po",
    "description": "GNU gettext PO file filter for the OpenCAT Framework",
    "type": "library",
    "version": "0.1.0",
    "require": {
        "php": "^8.2",
        "ext-mbstring": "*",
        "opencat/core": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "OpenCat\\FilterPo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenCat\\FilterPo\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {"type": "path", "url": "../core"}
    ]
}
